nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        setup {
            println "Downloading reduced Busco database..."
            def busco_mockdb_url = "https://tolit.cog.sanger.ac.uk/test-data/resources/busco/genomenote.GCA_963859965.1.2025-12-08.tar.gz"
            def busco_command = ['bash', '-c', "curl -L --retry 5 ${busco_mockdb_url} | tar xzf - -C ${launchDir}"]
            def busco_proc = busco_command.execute()
            busco_proc.waitFor()

            if (busco_proc.exitValue() != 0) {
                throw new RuntimeException("Error - failed to download Busco mock db: ${busco_proc.err.text}")
            }
        }

        when {
            params {
                outdir   = "$outputDir"
                busco_db = "${launchDir}/genomenote.GCA_963859965.1.2025-12-08"
            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we test pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/busco_software_mqc_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }
}

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {
        config "../conf/test_full.config"

        setup {
            curlAndExtract("https://tolit.cog.sanger.ac.uk/test-data/resources/busco/genomenote.GCA_963859965.1.2025-12-08.tar.gz", "${launchDir}/")

            // Download mapping files once for all tests
            def mapping_dir = new File("${launchDir}/mapping_files/")
            def raw_mapping_dir = new File("${launchDir}/raw_mapping_files/")
            mapping_dir.mkdirs()
            raw_mapping_dir.mkdirs()

            def all_mapping_files = [
                "archaea_odb10.2019-12-16", "bacteria_odb10.2019-12-16", "eukaryota_odb10.2019-12-16",
                "archaea_odb12.2024-11-15", "bacteria_odb12.2024-11-15", "eukaryota_odb12.2025-01-15",
            ]

            all_mapping_files.each { file_spec ->
                curlAndExtract("https://busco-data.s3.amazonaws.com/placement_files/mapping_taxids-busco_dataset_name.${file_spec}.txt.tar.gz", "${launchDir}/raw_mapping_files")
            }

            // Concatenate by version
            ['odb10', 'odb12'].each { version ->
                def version_files = all_mapping_files.findAll { it.contains(version) }
                if (version_files) {
                    def firstDate = version_files[0].split('\\.')[1]
                    def cmd = ['bash', '-c', "cat ${launchDir}/raw_mapping_files/*${version}* > ${launchDir}/mapping_files/${version}_mapping_file.${firstDate}.txt"]
                    def proc = cmd.execute()
                    proc.waitFor()
                    if (proc.exitValue() != 0) {
                        throw new RuntimeException("Error - failed to cat ${version}_mapping_file: ${proc.err.text}")
                    }
                }
            }
        }

        when {
            params {
                outdir      = "$outputDir"
                busco_db    = "/data/tol/resources/busco/latest"
                mapping_dir = "${launchDir}/mapping_files/"

            }
        }

        then {
            // stable_name: All files + folders in ${params.outdir}/ with a stable name
            def stable_name = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            // stable_path: All files in ${params.outdir}/ with stable content
            def stable_path = getAllFilesFromDir(params.outdir, ignoreFile: 'tests/.nftignore')
            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we test pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/busco_software_mqc_versions.yml"),
                    // All stable path name, with a relative path
                    stable_name,
                    // All files with stable contents
                    stable_path
                ).match() }
            )
        }
    }
}
